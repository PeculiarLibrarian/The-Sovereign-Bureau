@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix padi: <https://padi.tech/v2/schema#> .

### 1. The Class Hierarchy (The Structure)
padi:SovereignNode rdf:type owl:Class ;
    rdfs:label "Sovereign Node" ;
    rdfs:comment "An authoritative validation point within the PADI Bureau." .

padi:LiaisonAgent rdf:type owl:Class ;
    rdfs:label "Liaison Agent" ;
    rdfs:comment "A protocol-bound interface between a User and a Sovereign Node." .

### 2. The Properties (The Rules)
padi:hasIntegrityLevel rdf:type owl:DatatypeProperty ;
    rdfs:domain padi:SovereignNode ;
    rdfs:range xsd:integer ;
    rdfs:comment "Deterministic score of node reliability (0-100)." .

padi:validatesSubject rdf:type owl:ObjectProperty ;
    rdfs:domain padi:SovereignNode ;
    rdfs:range padi:LiaisonAgent ;
    rdfs:comment "The relationship defining which Agent is governed by which Node." .

### 3. The Nairobi-01 Instance (The Reality)
padi:Nairobi_01_Node rdf:type padi:SovereignNode ;
    padi:hasIntegrityLevel 100 ;
    rdfs:label "The Peculiar Librarian's Primary Node" .
